# =============================================================================
# Autonomous Drug Repurposing Platform — Environment Variables (TEMPLATE)
# =============================================================================
# v116 ROOT FIX (Teammate 15 — Infrastructure, issues IN-001/BE-004/P1-001/
# IN-049/IN-010/IN-006/IN-040): every secret that was previously HARDCODED in
# docker-compose.yml is now sourced from environment variables. This file is
# the committed TEMPLATE — copy it to `.env` and fill in real values.
#
# `.env` is gitignored (see .gitignore) and MUST NOT be committed.
#
# Generate the Fernet key + webserver secret with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# docker-compose.yml uses ${VAR:?ERROR} syntax for every secret — compose
# FAILS TO START if any required var is unset. This is the fail-fast guard
# that prevents the previous "dev_fernet_key_replace_in_production" silent
# fallback (IN-049).
#
# Usage:
#   cp .env.example .env
#   # edit .env and fill in real values
#   docker-compose --profile full-stack up -d
# =============================================================================

# ─── PostgreSQL (IN-001/BE-004/P1-001) ──────────────────────────────────────
# The staging/production DB superuser. CHANGE THESE FROM THE DEFAULTS.
POSTGRES_USER=drugos
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=drugos

# ─── Neo4j (IN-001) ─────────────────────────────────────────────────────────
NEO4J_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ─── Airflow (IN-049/IN-010) ────────────────────────────────────────────────
# AIRFLOW_FERNET_KEY must be a VALID 32-byte URL-safe base64 Fernet key.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# The previous value "dev_fernet_key_replace_in_production" is NOT a valid
# Fernet key and causes the Airflow container to crash at startup (IN-049).
AIRFLOW_FERNET_KEY=GENERATE_WITH_PYTHON_FERNET_GENERATE_KEY
# AIRFLOW_WEBSERVER_SECRET_KEY must be a random 32+ char string.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_WEBSERVER_SECRET_KEY=GENERATE_WITH_PYTHON_SECRETS_TOKEN_URLSAFE
# Airflow admin user (for the webserver UI — only needed if you run
# `docker-compose up phase1-airflow` with command: webserver)
AIRFLOW_ADMIN_USER=airflow_admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ─── MLflow (IN-009) ────────────────────────────────────────────────────────
MLFLOW_ADMIN_USERNAME=mlflow_admin
MLFLOW_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ─── Grafana (IN-040) ───────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# ─── Phase 3/4 Training (IN-007/IN-006) ─────────────────────────────────────
# GT_EPOCHS: number of Graph Transformer training epochs. The DOCX V1 launch
# criterion requires AUC > 0.85 — the canonical default is 80 (per
# run_4phase.py). Set to 5 for a quick smoke test (NOT for production).
GT_EPOCHS=80
# RL_TIMESTEPS: number of PPO timesteps for the RL ranker. Canonical default
# is 5000 (per run_4phase.py). Set to 100 for a smoke test.
RL_TIMESTEPS=5000

# ─── Phase 1 API keys (optional for sample mode) ────────────────────────────
# Required for FULL data download from DisGeNET and OMIM. Sample mode works
# without them. Register at https://www.disgenet.org/ and https://www.omim.org/
DISGENET_API_KEY=
OMIM_API_KEY=

# ─── Deployment environment ─────────────────────────────────────────────────
DRUGOS_ENVIRONMENT=production

# ─── IN-088 v117 ROOT FIX (Teammate 8): Docker Compose secrets directory ────
# docker-compose.yml now defines a top-level `secrets:` block that mounts
# each credential as a file in /run/secrets/<name>. The files are sourced
# from ./secrets/*.txt (gitignored). Create this directory and populate
# each file with the corresponding secret value:
#
#   mkdir -p secrets
#   echo -n "your_strong_postgres_password" > secrets/postgres_password.txt
#   echo -n "your_strong_neo4j_password" > secrets/neo4j_password.txt
#   echo -n "$(python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())')" > secrets/airflow_fernet_key.txt
#   echo -n "$(python -c 'import secrets; print(secrets.token_urlsafe(32))')" > secrets/airflow_webserver_secret_key.txt
#   echo -n "your_strong_mlflow_admin_password" > secrets/mlflow_admin_password.txt
#   echo -n "your_strong_grafana_admin_password" > secrets/grafana_admin_password.txt
#   chmod 600 secrets/*.txt   # restrict to owner-only
#
# The secrets/ directory is gitignored (see .gitignore). NEVER commit
# real secrets to git.
#
# The compose file still reads the env vars above (POSTGRES_PASSWORD,
# NEO4J_PASSWORD, etc.) for BACKWARD COMPATIBILITY — but the SECRET
# FILES take precedence (services that support _FILE suffix read from
# /run/secrets/ first, falling back to the env var).
#
# For production: use Docker Swarm secrets (`docker secret create`) or
# Kubernetes secrets. The compose file's `secrets:` block is compatible
# with both — just change `file: ./secrets/*.txt` to `external: true`
# and create the secrets via `docker secret create`.

# ─── SH-029 v117 ROOT FIX (Teammate 8): GT epochs env var ───────────────────
# DRUGOS_GT_EPOCHS: the production default for GT training epochs. The
# run_4phase.py CLI reads this env var as the default for --gt-epochs.
# Per DOCX §6, production deployments should set this to 500 (the
# canonical production value for AUC > 0.85). Dev/CI smoke tests leave
# it unset (defaults to 80).
# The docker-compose.yml phase3-trainer service sets this from ${GT_EPOCHS:-80}
# for backward compat — operators can use EITHER DRUGOS_GT_EPOCHS OR
# GT_EPOCHS (GT_EPOCHS takes precedence in the compose file).
DRUGOS_GT_EPOCHS=80
