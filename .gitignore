# v116 IN-001/BE-004/P1-001 ROOT FIX: root .env holds REAL secrets (Fernet
# key, DB passwords, API keys). It MUST NOT be committed. .env.example is
# the committed template with placeholders only.
.env
.env.*
!.env.example
# IN-088 v117 ROOT FIX (Teammate 8): Docker Compose secrets directory.
# The secrets/ directory holds file-based secrets mounted into containers
# via the compose `secrets:` block (postgres_password.txt, neo4j_password.txt,
# airflow_fernet_key.txt, etc.). These files contain REAL credentials and
# MUST NEVER be committed to git.
secrets/
secrets/*.txt
