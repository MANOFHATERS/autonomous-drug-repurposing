# =============================================================================
# Drug Repurposing ETL Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Every variable here is optional — defaults are defined in config/settings.py.
# =============================================================================

# --- Environment ---
# development: relaxed validation, debug logging, small processing limits
# staging:     production-like with moderate limits
# production:  strict validation, warning-level logging, no limits
ENVIRONMENT=development

# --- Database ---
# PostgreSQL connection string.
# In development, docker-compose defaults (cosmic:cosmic) are auto-applied.
# In staging/production, this MUST be set explicitly.
DATABASE_URL=postgresql://cosmic:cosmic@localhost:5432/drug_repurposing

# --- API Keys (free academic registrations) ---

# DisGeNET API key (required for data download via REST API)
# Register at https://www.disgenet.org/ to obtain an API key
DISGENET_API_KEY=your_api_key_here

# Set to "true" (default) to use DisGeNET REST API.
# Set to "false" to fall back to deprecated static file download (not recommended).
DISGENET_USE_API=true

# OMIM API key — required for gene-phenotype mapping data
# Register at https://www.omim.org/ to obtain an API key
OMIM_API_KEY=

# --- DrugBank ---
# Path to DrugBank XML file (requires paid license, manual download)
# DrugBank distributes the full database as a .xml.gz file.
# Common filenames: drugbank_all_full_database.xml.gz, full database.xml.gz
DRUGBANK_XML_PATH=

# --- ChEMBL ---
# ChEMBL database release version (default: 35)
# Known valid versions: 30, 31, 32, 33, 34, 35
CHEMBL_VERSION=35

# ChEMBL REST API base URL (default: https://www.ebi.ac.uk/chembl/api/data)
CHEMBL_API_URL=https://www.ebi.ac.uk/chembl/api/data

# ChEMBL snapshot date for reproducibility (empty = latest)
# If set, molecules are filtered by modification_date <= this date.
# Format: YYYY-MM-DD (e.g., 2024-06-01)
CHEMBL_SNAPSHOT_DATE=

# Processing limits (0 = unlimited, None/unset = unlimited)
# In development profile, CHEMBL_MAX_ROWS defaults to 1000 for fast iteration.
CHEMBL_MAX_ROWS=0
# Separate limit for activities (bioactivity data)
CHEMBL_MAX_ACTIVITIES=0

# ChEMBL count validation thresholds
# ChEMBL v35 max_phase=4 returns ~3500-4000 molecules, NOT 8000-15000.
# The 8000-15000 range covers ALL clinical phases (0-4), not just approved.
# These are auto-set based on CHEMBL_VERSION but can be overridden.
CHEMBL_DRUG_COUNT_MIN=3000
CHEMBL_DRUG_COUNT_MAX=5000

# --- STRING DB ---
# STRING database version (default: 12.0)
# Available versions: 11.0, 11.0b, 11.5, 12.0 (12.5 does NOT exist)
STRING_VERSION=12.0

# Minimum combined score for PPI inclusion (0-1000)
# v57 ROOT FIX (P1C-003): the previous default was 400, which the STRING-db
# documentation classifies as "low confidence" (~50% precision). The
# scientifically-validated threshold for >80% precision is 700. Operators
# who copied .env.example were silently degrading PPI graph quality by
# ~30 precision points.
# Default: 700 (high-confidence PPI only)
# Lower to 400 for exploratory analysis; raise to 800+ for stringent graphs.
STRING_MIN_COMBINED_SCORE=700
# Alias for backward compatibility (some tests check STRING_MIN_SCORE):
STRING_MIN_SCORE=700

# --- UniProt ---
# UniProt release for reproducibility.
# Default: 'current_release' (non-reproducible — different data each run)
# Pin a specific release for production: e.g., 'releases/2024_03'
UNIPROT_RELEASE=current_release

# --- PubChem ---
# PubChem REST API base URL
PUBCHEM_REST_BASE=https://pubchem.ncbi.nlm.nih.gov/rest/pug
# PubChem FTP base URL (for future bulk download capability)
PUBCHEM_FTP_BASE=https://ftp.ncbi.nlm.nih.gov/pubchem

# --- Data Provenance ---
# Unique identifier for this data configuration snapshot.
# Auto-generated from source versions + date if not set.
# Set explicitly for reproducible runs.
DATA_SNAPSHOT_ID=

# --- Project Root ---
# Override project root directory detection (auto-detected by default)
# PROJECT_ROOT=/path/to/project

# --- Logging ---
# Platform logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
