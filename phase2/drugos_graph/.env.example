# DrugOS Graph Module — Environment Variables
# Copy this file to .env and fill in the values.
#
# v43 ROOT FIX (Chain 7 — .env.example incomplete): the previous
# version documented only 3 of 249 env vars. Operators had no way to
# discover critical configuration without reading source code. This
# file now documents the most important env vars grouped by category.
# For the complete list, run:
#   grep -rhoE "os.environ.get\(['\"]([A-Z_]+)['\"]" phase1/ phase2/ \
#     | sed -E "s/.*['\"]([A-Z_]+)['\"].*/\1/" | sort -u

# ═══════════════════════════════════════════════════════════════════════
# CRITICAL — Production deployment requires these to be set
# ═══════════════════════════════════════════════════════════════════════

# DRUGOS_ENVIRONMENT: dev | production. Critical for patient safety.
#   - dev (default): allows DRUGOS_ALLOW_LAUNCH_FAIL, dev smoke tests,
#     relaxed V1 launch criteria.
#   - production: STRICT mode. DRUGOS_ALLOW_LAUNCH_FAIL is IGNORED.
#     V1 launch criteria failure always raises.
DRUGOS_ENVIRONMENT=dev

# DATABASE_URL: PostgreSQL connection string for Phase 1 staging DB.
#   Required for production. SQLite fallback for dev only.
#   Format: postgresql+psycopg2://user:password@host:5432/dbname
# DATABASE_URL=postgresql+psycopg2://drugos:drugos@localhost:5432/drugos

# DRUGBANK_XML_PATH: Path to DrugBank XML file (downloaded separately
#   due to license). Required for DrugBank pipeline.
# DRUGBANK_XML_PATH=/data/drugbank/drugbank.xml

# DISGENET_API_KEY: Required for DisGeNET API access (free academic
#   license at https://disgenet.com/plans). Without this, the pipeline
#   falls back to the deprecated static URL.
# DISGENET_API_KEY=your-api-key-here

# ═══════════════════════════════════════════════════════════════════════
# Neo4j Database (Phase 2 knowledge graph store)
# ═══════════════════════════════════════════════════════════════════════
DRUGOS_NEO4J_PASSWORD=
# DRUGOS_NEO4J_URI=bolt://localhost:7687
# DRUGOS_NEO4J_USER=neo4j
# DRUGOS_NEO4J_DATABASE=neo4j

# ═══════════════════════════════════════════════════════════════════════
# MLflow (experiment tracking — required for V1 launch criteria)
# ═══════════════════════════════════════════════════════════════════════
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_TRACKING_USERNAME=
# MLFLOW_TRACKING_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════
# HuggingFace (ChemBERTa encoder — required for Compound features)
# ═══════════════════════════════════════════════════════════════════════
# HF_HOME=~/.cache/huggingface
# HF_TOKEN=your-hf-token  # required for some models
# HF_HUB_OFFLINE=0  # set to 1 for air-gapped deployments

# ═══════════════════════════════════════════════════════════════════════
# V1 Launch Criteria (patient safety gates)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_ALLOW_LAUNCH_FAIL: 0 (default) | 1.
#   v43 ROOT FIX (Chain 5): IGNORED in production. In dev mode, allows
#   the pipeline to continue despite V1 launch criteria failure. The
#   shipped model MUST NOT be used for V1 launch sign-off.
# DRUGOS_ALLOW_LAUNCH_FAIL=0

# DRUGOS_DEV_SMOKE_TEST: 0 | 1. Relaxes V1 criteria for dev smoke tests.
# DRUGOS_DEV_SMOKE_TEST=0

# DRUGOS_DEV_SMOKE_TEST_MIN_AUC: minimum AUC for dev smoke test pass.
# DRUGOS_DEV_SMOKE_TEST_MIN_AUC=0.55

# DRUGOS_TARGET_AUC: V1 launch AUC threshold (DOCX spec: 0.85).
# DRUGOS_TARGET_AUC=0.85

# ═══════════════════════════════════════════════════════════════════════
# ML Training (TransE + Graph Transformer)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_TRANSE_EMBEDDING_DIM: embedding dimension (default 256).
# DRUGOS_TRANSE_EMBEDDING_DIM=256

# DRUGOS_TRANSE_MARGIN: margin for margin-ranking loss (default 1.0).
# DRUGOS_TRANSE_MARGIN=1.0

# DRUGOS_TRANSE_LR: learning rate (default 0.01).
# DRUGOS_TRANSE_LR=0.01

# DRUGOS_TRANSE_EPOCHS: training epochs (default 100).
# DRUGOS_TRANSE_EPOCHS=100

# DRUGOS_TRANSE_BATCH_SIZE: batch size (default 256).
# DRUGOS_TRANSE_BATCH_SIZE=256

# DRUGOS_TRANSE_SCORE_DIRECTION: lower_better (TransE) | higher_better
#   (HGT/similarity-based). v43 ROOT FIX (Chain 5): GraphTransformer
#   uses higher_better.
# DRUGOS_TRANSE_SCORE_DIRECTION=lower_better

# DRUGOS_NEG_RATIO: negative-to-positive ratio for training (default 10).
# DRUGOS_NEG_RATIO=10

# DRUGOS_TEMPORAL_CUTOFF_YEAR: year cutoff for temporal split (default 2020).
# DRUGOS_TEMPORAL_CUTOFF_YEAR=2020

# DRUGOS_NEGATIVE_CACHE_SIZE: cache size for negative sampling (default 10000).
# DRUGOS_NEGATIVE_CACHE_SIZE=10000

# DRUGOS_MIN_NEGATIVE_PAIRS: minimum negative pairs for training (default 50).
# DRUGOS_MIN_NEGATIVE_PAIRS=50

# ═══════════════════════════════════════════════════════════════════════
# Negative Sampling (v43 ROOT FIX Chain 6 — Bernoulli degree-weighted)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_NEG_SAMPLING_METHOD: bernoulli (default, v43) | uniform.
#   Bernoulli: weight entities by degree (Wang et al. 2014).
#   Uniform: equal probability per entity (biased against hubs).
# DRUGOS_NEG_SAMPLING_METHOD=bernoulli

# ═══════════════════════════════════════════════════════════════════════
# ChemBERTa encoder (Compound molecular features)
# ═══════════════════════════════════════════════════════════════════════
# v71 ROOT FIX (P2C-006): the previous comment said "default
# chemberta-77m-mlm" and the example used
# "seyonec/ChemBERTa-77M-MLM" — but the CODE default in
# chemberta_encoder.py is "seyonec/ChemBERTa-zinc-base-v1". Operators
# copying .env.example to .env got a DIFFERENT model than the code
# default, producing non-reproducible embeddings. The comment + example
# now match the code default exactly.
# DRUGOS_CHEMBERTA_MODEL: HuggingFace model name. The default
# "seyonec/ChemBERTa-zinc-base-v1" is PUBLIC on HuggingFace (no token
# required). v71 P2C-003: gating status is auto-detected via
# huggingface_hub.model_info — HF_TOKEN is only required for genuinely
# gated models.
# DRUGOS_CHEMBERTA_MODEL=seyonec/ChemBERTa-zinc-base-v1

# DRUGOS_CHEMBERTA_REVISION: model revision pin (default main).
# DRUGOS_CHEMBERTA_REVISION=main

# DRUGOS_CHEMBERTA_BATCH_SIZE: encoding batch size (default 32).
# DRUGOS_CHEMBERTA_BATCH_SIZE=32

# DRUGOS_CHEMBERTA_MAX_LENGTH: token max length (default 256).
# DRUGOS_CHEMBERTA_MAX_LENGTH=256

# DRUGOS_CHEMBERTA_CACHE_DIR: cache directory for embeddings.
# DRUGOS_CHEMBERTA_CACHE_DIR=

# DRUGOS_CHEMBERTA_DTYPE: model dtype (default float32 | float16).
# DRUGOS_CHEMBERTA_DTYPE=float32

# DRUGOS_CHEMBERTA_FORCE_REFRESH: 0 | 1. Force re-encode all compounds.
# DRUGOS_CHEMBERTA_FORCE_REFRESH=0

# DRUGOS_CHEMBERTA_NO_CACHE: 0 | 1. Disable embedding cache.
# DRUGOS_CHEMBERTA_NO_CACHE=0

# DRUGOS_CHEMBERTA_SAMPLE_SIZE: subsample size for health checks.
# DRUGOS_CHEMBERTA_SAMPLE_SIZE=100

# ═══════════════════════════════════════════════════════════════════════
# Data sources — staleness and freshness
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_DATA_MAX_AGE_DAYS: max age before data is considered stale (default 30).
# DRUGOS_DATA_MAX_AGE_DAYS=30

# DRUGOS_DATA_STALENESS_DAYS: warning threshold for stale data (default 7).
# DRUGOS_DATA_STALENESS_DAYS=7

# DRUGOS_ALLOW_STALE_CSV: 0 | 1. Allow stale CSVs without warning.
# DRUGOS_ALLOW_STALE_CSV=0

# DRUGOS_DISGENET_MAX_AGE_DAYS: DisGeNET data max age (default 30).
# DRUGOS_DISGENET_MAX_AGE_DAYS=30

# DRUGOS_OMIM_MAX_AGE_DAYS: OMIM data max age (default 90).
# DRUGOS_OMIM_MAX_AGE_DAYS=90

# ═══════════════════════════════════════════════════════════════════════
# DisGeNET
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_DISGENET_MIN_SCORE: minimum DSGP score (default 0.06, Piñero 2020).
# DRUGOS_DISGENET_MIN_SCORE=0.06

# ═══════════════════════════════════════════════════════════════════════
# OMIM
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_OMIM_MIN_SCORE: minimum OMIM score (default 0.5).
# DRUGOS_OMIM_MIN_SCORE=0.5

# DRUGOS_OMIM_STRICT_HGNC: 0 | 1. Reject non-HGNC gene symbols.
# DRUGOS_OMIM_STRICT_HGNC=0

# ═══════════════════════════════════════════════════════════════════════
# ChEMBL
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_CHEMBL_MIN_CONFIDENCE: minimum ChEMBL confidence score (default 0.4).
# DRUGOS_CHEMBL_MIN_CONFIDENCE=0.4

# DRUGOS_CHEMBL_MIN_PCHEMBL: minimum pChEMBL value (default 5.0).
# DRUGOS_CHEMBL_MIN_PCHEMBL=5.0

# DRUGOS_CHEMBL_TAX_ID: NCBI taxonomy ID (default 9606 = human).
# DRUGOS_CHEMBL_TAX_ID=9606

# DRUGOS_MAX_CHEMBL_ENTRIES: cap ChEMBL entries for dev (default unlimited).
# DRUGOS_MAX_CHEMBL_ENTRIES=

# ═══════════════════════════════════════════════════════════════════════
# DrugBank
# ═══════════════════════════════════════════════════════════════════════
# DRUGBANK_MEMORY_CEILING_MB: memory limit for XML parsing (default 4096).
# DRUGBANK_MEMORY_CEILING_MB=4096

# DRUGBANK_CHECKPOINT_INTERVAL: checkpoint every N drugs (default 1000).
# DRUGBANK_CHECKPOINT_INTERVAL=1000

# ═══════════════════════════════════════════════════════════════════════
# Entity Resolution
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_ENTITY_CONFIDENCE_THRESHOLD: fuzzy match threshold (default 0.6).
#   v43 note: this matches drug_resolver._FUZZY_THRESHOLD. The previous
#   config default was 0.85 — divergent.
# DRUGOS_ENTITY_CONFIDENCE_THRESHOLD=0.6

# DRUGOS_ENTITY_RESOLVER_LRU_CACHE_SIZE: LRU cache size (default 10000).
# DRUGOS_ENTITY_RESOLVER_LRU_CACHE_SIZE=10000

# DRUGOS_ER_CIRCUIT_BREAKER_FAILURE_THRESHOLD: ER circuit breaker (default 10).
# DRUGOS_ER_CIRCUIT_BREAKER_FAILURE_THRESHOLD=10

# DRUGOS_ER_CIRCUIT_BREAKER_RESET_SECONDS: reset timeout (default 60).
# DRUGOS_ER_CIRCUIT_BREAKER_RESET_SECONDS=60

# ═══════════════════════════════════════════════════════════════════════
# Determinism / Reproducibility
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_DETERMINISTIC_MODE: 0 | 1. Force deterministic algorithms.
#   Required for FDA 21 CFR Part 11 reproducibility.
# DRUGOS_DETERMINISTIC_MODE=0

# DRUGOS_DETERMINISTIC: alias for DRUGOS_DETERMINISTIC_MODE.
# DRUGOS_DETERMINISTIC=0

# ═══════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_LOG_LEVEL: DEBUG | INFO | WARNING | ERROR (default INFO).
# DRUGOS_LOG_LEVEL=INFO

# DRUGOS_LOG_MAX_BYTES: max log file size in bytes (default 10485760 = 10MB).
# DRUGOS_LOG_MAX_BYTES=10485760

# DRUGOS_LOG_BACKUP_COUNT: number of backup log files (default 5).
# DRUGOS_LOG_BACKUP_COUNT=5

# ═══════════════════════════════════════════════════════════════════════
# Dead Letter Queue
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_DEAD_LETTER_DIR: directory for quarantined records.
# DRUGOS_DEAD_LETTER_DIR=

# DRUGOS_DLQ_SAMPLE_CAP: max DLQ records to sample for logging (default 100).
# DRUGOS_DLQ_SAMPLE_CAP=100

# ═══════════════════════════════════════════════════════════════════════
# Knowledge Graph Schema
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_KG_ALLOW_NON_CORE_EDGES: 0 | 1. Allow non-CORE_EDGE_TYPES edges.
# DRUGOS_KG_ALLOW_NON_CORE_EDGES=0

# DRUGOS_KG_AUTO_DEDUP: 0 | 1. Auto-deduplicate edges on load.
# DRUGOS_KG_AUTO_DEDUP=1

# DRUGOS_EDGE_DEDUP_EARLY_REDUCTION_THRESHOLD: dedup threshold (default 100000).
# DRUGOS_EDGE_DEDUP_EARLY_REDUCTION_THRESHOLD=100000

# ═══════════════════════════════════════════════════════════════════════
# Security
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_ENCRYPT_AT_REST: 0 | 1. Encrypt sensitive columns at rest.
# DRUGOS_ENCRYPT_AT_REST=0

# DRUGOS_MAPPING_ENCRYPTION_KEY: encryption key for entity mapping table.
# DRUGOS_MAPPING_ENCRYPTION_KEY=

# ═══════════════════════════════════════════════════════════════════════
# Evaluation
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_EVAL_ROLE: train | val | test. Role for evaluation run.
# DRUGOS_EVAL_ROLE=test

# DRUGOS_EVAL_CONFIG: path to evaluation config file.
# DRUGOS_EVAL_CONFIG=

# ═══════════════════════════════════════════════════════════════════════
# Dev mode relaxations (IGNORED in production)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_DEV_ALLOW_NO_SAMPLER: 0 | 1. Allow training without sampler.
# DRUGOS_DEV_ALLOW_NO_SAMPLER=0

# DRUGOS_ALLOW_NO_SAMPLER: 0 | 1. Production escape hatch for no-sampler.
#   IGNORED if DRUGOS_ENVIRONMENT=production.
# DRUGOS_ALLOW_NO_SAMPLER=0

# DRUGOS_DEV_MIN_POSITIVE_PAIRS: dev minimum positive pairs (default 5).
# DRUGOS_DEV_MIN_POSITIVE_PAIRS=5

# DRUGOS_DEV_MIN_NEGATIVE_PAIRS: dev minimum negative pairs (default 18).
# DRUGOS_DEV_MIN_NEGATIVE_PAIRS=18

# DRUGOS_DEV_MIN_SOURCES: dev minimum sources loaded (default 3).
# DRUGOS_DEV_MIN_SOURCES=3

# DRUGOS_DEV_STRICT_AUC: 0 | 1. Strict AUC enforcement in dev.
# DRUGOS_DEV_STRICT_AUC=0

# DRUGOS_ALLOW_NO_YEAR_IN_TRAIN: 0 | 1. Allow pairs without approval_year.
# DRUGOS_ALLOW_NO_YEAR_IN_TRAIN=0

# ═══════════════════════════════════════════════════════════════════════
# Phase 1 database connection (PostgreSQL)
# ═══════════════════════════════════════════════════════════════════════
# DATABASE_SSL_MODE: prefer | require | verify-ca | verify-full | disable.
# DATABASE_SSL_MODE=prefer

# DATABASE_ISOLATION_LEVEL: READ COMMITTED | REPEATABLE READ | SERIALIZABLE.
# DATABASE_ISOLATION_LEVEL=READ COMMITTED

# DATABASE_CONNECT_ARGS: JSON-encoded connect args (e.g. {"connect_timeout": 30}).
# DATABASE_CONNECT_ARGS={"connect_timeout": 30}

# DATABASE_LAZY_IMPORT: 0 | 1. Lazy-load database module (faster import).
# DATABASE_LAZY_IMPORT=1

# ═══════════════════════════════════════════════════════════════════════
# Airflow (Phase 1 DAGs)
# ═══════════════════════════════════════════════════════════════════════
# AIRFLOW_USER: username for Airflow context (auto-set by Airflow).
# AIRFLOW_CTX_DAG_ID: DAG ID for Airflow context (auto-set by Airflow).

# APP_ENV: application environment alias (dev | staging | production).
# APP_ENV=dev

# ═══════════════════════════════════════════════════════════════════════
# STRING (Phase 1)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_STRING_MIN_COMBINED_SCORE: STRING PPI confidence threshold.
#   v43 ROOT FIX (Chain 7): default 700 (HIGH confidence per
#   Szklarczyk 2023). Previous code defaulted to 400 (MEDIUM) in some
#   paths. 400 = ~50% precision; 700 = ~80% precision.
# DRUGOS_STRING_MIN_COMBINED_SCORE=700

# ═══════════════════════════════════════════════════════════════════════
# ClinicalTrials.gov (Phase 2)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_CLINICALTRIALS_OFFLINE: 0 | 1. Skip network download.
# DRUGOS_CLINICALTRIALS_OFFLINE=0

# DRUGOS_CLINICALTRIALS_SKIP: 0 | 1. Skip ClinicalTrials loader entirely.
# DRUGOS_CLINICALTRIALS_SKIP=0

# DRUGOS_CLINICALTRIALS_FORCE_DOWNLOAD: 0 | 1. Force re-download.
# DRUGOS_CLINICALTRIALS_FORCE_DOWNLOAD=0

# DRUGOS_CLINICALTRIALS_ALLOW_STALE: 0 | 1. Allow stale data.
# DRUGOS_CLINICALTRIALS_ALLOW_STALE=0

# DRUGOS_CLINICALTRIALS_ALLOW_LEGACY: 0 | 1. Allow legacy format.
# DRUGOS_CLINICALTRIALS_ALLOW_LEGACY=0

# ═══════════════════════════════════════════════════════════════════════
# OpenTargets (Phase 2)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_OPENTARGETS_FORCE_DOWNLOAD: 0 | 1. Force re-download.
# DRUGOS_OPENTARGETS_FORCE_DOWNLOAD=0

# DRUGOS_OPENTARGETS_MAX_RETRIES: max download retries (default 3).
# DRUGOS_OPENTARGETS_MAX_RETRIES=3

# DRUGOS_OPENTARGETS_DOWNLOAD_TIMEOUT: download timeout seconds (default 600).
# DRUGOS_OPENTARGETS_DOWNLOAD_TIMEOUT=600

# DRUGOS_OPENTARGETS_CHUNK_SIZE: processing chunk size (default 10000).
# DRUGOS_OPENTARGETS_CHUNK_SIZE=10000

# DRUGOS_OPENTARGETS_MAX_ROWS: cap rows for dev (default unlimited).
# DRUGOS_OPENTARGETS_MAX_ROWS=

# ═══════════════════════════════════════════════════════════════════════
# GEO (Phase 2)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_GEO_OFFLINE: 0 | 1. Skip GEO network access.
# DRUGOS_GEO_OFFLINE=0

# ═══════════════════════════════════════════════════════════════════════
# DRKG (Phase 2 baseline dataset)
# ═══════════════════════════════════════════════════════════════════════
# DRUGOS_DRKG_DIR: DRKG data directory.
# DRUGOS_DRKG_DIR=

# DRUGOS_DRKG_FORCE_DOWNLOAD: 0 | 1. Force re-download.
# DRUGOS_DRKG_FORCE_DOWNLOAD=0

# DRUGOS_DRKG_ALLOW_STALE: 0 | 1. Allow stale DRKG data.
# DRUGOS_DRKG_ALLOW_STALE=0

# DRUGOS_DRKG_CHECKPOINT_EVERY: checkpoint every N rows (default 100000).
# DRUGOS_DRKG_CHECKPOINT_EVERY=100000
