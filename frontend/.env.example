# =============================================================================
# Autonomous Drug Repurposing Platform — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and edit the values for your environment.
#
# The 4 Python services (Phase 1/2/3/4) run as separate processes. The
# Next.js frontend proxies to them via the *_SERVICE_URL env vars below.
# In docker-compose, these point to the service names (e.g. http://phase1-service:8001).
# In local dev, they point to localhost (e.g. http://localhost:8001).
#
# Step 2 of the integration plan (v105) wires all 4 phases:
#   Phase 1 -> DATASET_SERVICE_URL  (/api/dataset)
#   Phase 2 -> KG_SERVICE_URL       (/api/knowledge-graph)
#   Phase 3 -> GT_SERVICE_URL       (/api/predict)  <- NEW in v105
#   Phase 4 -> RL_SERVICE_URL       (/api/rl)
# =============================================================================

# ─── Phase 1: Dataset Service ──────────────────────────────────────────────
# FastAPI service wrapping Phase 1 ETL. Endpoints: /health, /datasets,
# /datasets/{drug}/mechanism. Run with: python phase1/service.py
DATASET_SERVICE_URL=http://localhost:8001

# ─── Phase 2: Knowledge Graph Service ──────────────────────────────────────
# FastAPI service wrapping Phase 2 KG builder. Endpoints: /health,
# /kg/stats, /kg/explore. Run with: python phase2/service.py
KG_SERVICE_URL=http://localhost:8002

# ─── Phase 3: Graph Transformer Service ────────────────────────────────────
# FastAPI service wrapping Phase 3 GT model inference. Endpoints:
# /health, /predict, /top-k. Run with: python graph_transformer/service.py
# RT-006 v105: this is the NEW connection — previously the frontend had
# NO way to reach Phase 3, so the GT model's scores were invisible to
# the dashboard. The new /api/predict route proxies to this URL.
GT_SERVICE_URL=http://localhost:8003

# ─── Phase 4: RL Hypothesis Ranker Service ─────────────────────────────────
# FastAPI service wrapping Phase 4 RL ranker. Endpoints: /health, /rank,
# /rank/{drug}. Run with: python rl/service.py
RL_SERVICE_URL=http://localhost:8004

# ─── Database (Prisma) ─────────────────────────────────────────────────────
# PostgreSQL URL for the frontend's own Prisma DB (users, projects,
# hypotheses, audit logs). NOT the Phase 1 staging DB.
DATABASE_URL="postgresql://drugos:drugos@localhost:5432/drugos?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────
# NextAuth.js configuration. Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Neo4j (optional, for Phase 2 service in production) ───────────────────
# When set, the Phase 2 service reads KG stats from Neo4j instead of
# building the graph in-memory from CSVs.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── RL ranker CSV output (optional override) ──────────────────────────────
# FE-003 v105: by default the frontend auto-discovers the latest
# top_candidates_*.csv in ../rl/. Set this to override the search path.
# RL_OUTPUT_CSV_PATH=/absolute/path/to/top_candidates_xxx.csv
