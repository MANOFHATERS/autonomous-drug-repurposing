# =============================================================================
# Autonomous Drug Repurposing Platform — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and edit the values for your environment.
#
# The 4 Python services (Phase 1/2/3/4) run as separate processes. The
# Next.js frontend proxies to them via the *_SERVICE_URL env vars below.
# In docker-compose, these point to the service names (e.g. http://phase1-service:8001).
# In local dev, they point to localhost (e.g. http://localhost:8001).
#
# Issue 240 ROOT FIX: the 4 service URLs are now documented here with
# their EXACT endpoint contracts. All ML-integration API routes proxy
# to these services via the shared HTTP client (frontend/src/lib/http-client.ts).
# There are NO subprocess paths and NO local file fallbacks — the Python
# services are the single source of truth for all ML output.
#
#   Phase 1 -> PHASE1_SERVICE_URL  (/api/dataset proxies to /stats)
#   Phase 2 -> KG_SERVICE_URL      (/api/knowledge-graph proxies to /kg/stats, /kg/explore, /query, /cypher)
#   Phase 3 -> GT_SERVICE_URL      (/api/predict proxies to /predict; /api/top-k proxies to /top-k)
#   Phase 4 -> RL_SERVICE_URL      (/api/rl proxies to /rank; /api/hypothesis/validate proxies to /validate)
# =============================================================================

# ─── Phase 1: Dataset Service ──────────────────────────────────────────────
# FastAPI service wrapping Phase 1 ETL. Endpoints: /health, /datasets,
# /datasets/{drug}/mechanism, /stats. Run with: python phase1/service.py
#
# Issue 233 ROOT FIX: the canonical env var is PHASE1_SERVICE_URL (matches
# the naming convention of GT_SERVICE_URL / RL_SERVICE_URL / KG_SERVICE_URL).
# DATASET_SERVICE_URL is honored as a LEGACY ALIAS for deployments that
# haven't renamed their env vars yet — PHASE1_SERVICE_URL wins if both are set.
PHASE1_SERVICE_URL=http://localhost:8001
# Legacy alias (optional — unset if you've migrated to PHASE1_SERVICE_URL):
# DATASET_SERVICE_URL=http://localhost:8001

# ─── Phase 2: Knowledge Graph Service ──────────────────────────────────────
# FastAPI service wrapping Phase 2 KG builder. Endpoints: /health,
# /kg/stats, /kg/explore, /query, /cypher. Run with: python phase2/service.py
#
# Issue 232 ROOT FIX: the frontend now calls /kg/stats (NOT /stats) and
# /kg/explore (NOT /lookup). The previous version called wrong URLs which
# 404'd. The new kg-service.ts aligns with the Python service's actual
# endpoints.
KG_SERVICE_URL=http://localhost:8002

# ─── Phase 3: Graph Transformer Service ────────────────────────────────────
# FastAPI service wrapping Phase 3 GT model inference. Endpoints:
# /health, /predict, /top-k. Run with: python graph_transformer/service.py
#
# Issue 230 ROOT FIX: the frontend's gt-inference.ts is now HTTP-ONLY.
# There is no subprocess fallback. If GT_SERVICE_URL is not set, the
# /api/predict and /api/top-k routes return source:"none" with a clear
# message telling the operator to set this env var.
#
# The service requires GT_CHECKPOINT_PATH to point to a trained .pt file.
# If the checkpoint is missing, /predict and /top-k return 503.
GT_SERVICE_URL=http://localhost:8003
# GT_CHECKPOINT_PATH=/path/to/gt_checkpoint.pt
# GT_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Phase 4: RL Hypothesis Ranker Service ─────────────────────────────────
# FastAPI service wrapping Phase 4 RL ranker. Endpoints: /health, /rank,
# /rank/{drug}, /validate. Run with: python rl/service.py
#
# Issue 231 ROOT FIX: the frontend's rl-ranker.ts is now HTTP-ONLY.
# There is no CSV fallback. If RL_SERVICE_URL is not set, the /api/rl
# route returns source:"none" with a clear message.
#
# Issue 227 ROOT FIX: the /api/hypothesis/validate route now proxies to
# RL_SERVICE_URL/validate (added to rl/service.py in this commit). The
# previous version spawned a subprocess to scripts/hypothesis_writeback.py
# which did not exist at the resolved path.
RL_SERVICE_URL=http://localhost:8004
# RL_CHECKPOINT_PATH=/path/to/ppo_checkpoint.zip
# RL_CORS_ORIGINS=http://localhost:3000
# RL_STRICT_CHECKPOINT=true  # set to false to allow CSV fallback when checkpoint fails

# ─── Database (Prisma) ─────────────────────────────────────────────────────
# PostgreSQL URL for the frontend's own Prisma DB (users, projects,
# hypotheses, audit logs). NOT the Phase 1 staging DB.
DATABASE_URL="postgresql://drugos:drugos@localhost:5432/drugos?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────
# NextAuth.js configuration. Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# ─── Neo4j (optional, for Phase 2 service in production) ───────────────────
# When set, the Phase 2 service reads KG stats from Neo4j instead of
# building the graph in-memory from CSVs.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── NCBI / ClinicalTrials.gov / openFDA API keys (optional) ───────────────
# These are used by the evidence-package service to query real biomedical
# databases. Without keys, the services use lower rate limits.
# NCBI_API_KEY=
# CTGOV_API_KEY=
# OPENFDA_API_KEY=
