# =============================================================================
# Autonomous Drug Repurposing Platform — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and edit the values for your environment.
#
# TEAMMATE-4 + TEAMMATE-8 ROOT FIX (Backend + Frontend Integration):
#   The frontend NO LONGER calls the Phase 1/2/3/4 Python services
#   directly. Instead, it calls /api/* Next.js routes which proxy to
#   the FastAPI backend (BACKEND_URL). The backend then proxies to the
#   Python services (PHASE1_SERVICE_URL, KG_SERVICE_URL, etc.).
#
#   Architecture:
#     Browser -> Next.js /api/datasets/stats -> FastAPI /datasets/stats
#                                            -> Phase 1 /stats
#     Browser -> Next.js /api/kg/stats       -> FastAPI /kg/stats
#                                            -> Phase 2 /kg/stats
#
#   This routes all ML calls through the FastAPI backend so we can
#   enforce JWT auth, org_id scoping, rate limiting, and 503 fallback
#   at a single chokepoint. The Python services are now INTERNAL ONLY
#   (they should not be exposed to the browser — lock down their CORS
#   to only accept requests from the backend).
#
#   Migration: previously each Python service had its own *_SERVICE_URL
#   env var on the frontend (PHASE1_SERVICE_URL, GT_SERVICE_URL, etc.).
#   Those are now DEPRECATED on the frontend — they live on the backend
#   instead. The frontend only needs BACKEND_URL.
#
# TEAMMATE-8 ADDITIONAL ROOT FIX (P2 port collision):
#   The backend FastAPI service runs on port 8004 (per backend/api/main.py
#   L75: `uvicorn main:app --host 0.0.0.0 --port 8004 --workers 4`). The
#   PREVIOUS version of this file said port 8000, but 8000 is the
#   canonical phase1_dataset port per SERVICE_PORTS in
#   contracts/_url-constants.ts — running FastAPI on 8000 would collide
#   with the Phase 1 dataset service on the same host. Port 8004 is the
#   canonical backend_fastapi port per SERVICE_PORTS.
# =============================================================================

# ─── Backend (FastAPI public REST API) ─────────────────────────────────────
# The FastAPI backend's URL. The Next.js /api/predict, /api/top-k, /api/kg/*,
# /api/datasets/* routes ALL proxy to this URL via mlFetch.
# In docker-compose: http://backend:8004
# In local dev: http://localhost:8004
#
# FE-001 ROOT FIX (Teammate 13, v143): the canonical env var is now
# DRUGOS_API_URL (matches the FastAPI's own DRUGOS_API_PORT convention
# in backend/api/main.py). BACKEND_URL is kept as a legacy alias for
# backward compat with deployments that already use it — DRUGOS_API_URL
# wins if both are set.
#
# Port 8004 (canonical backend_fastapi port per SERVICE_PORTS in
# contracts/_url-constants.ts — matches `uvicorn main:app --port 8004`
# in backend/api/main.py L75).
# Run with: python -m backend.api.main  (or uvicorn backend.api.main:app --port 8004)
#
# DRUGOS_API_URL (canonical, FE-001 Teammate 13 v143) and BACKEND_URL
# (legacy alias, Teammate 8) and BACKEND_SERVICE_URL (legacy alias,
# Teammate 4) are ALL accepted — DRUGOS_API_URL wins if multiple are set.
DRUGOS_API_URL=http://localhost:8004
# Legacy aliases (kept for backward compat):
# BACKEND_URL=http://localhost:8004
# BACKEND_SERVICE_URL=http://localhost:8004

# ─── Phase 1: Dataset Service (DEPRECATED on frontend — now on backend) ────
# PHASE1_SERVICE_URL is NO LONGER USED by the frontend. It now lives on
# the backend (the FastAPI service's PHASE1_SERVICE_URL env var points
# to the Phase 1 service).
#
# To set it on the backend, use:
#   export PHASE1_SERVICE_URL=http://localhost:8000  (on the backend process — FE-002 v143: canonical phase1_dataset port is 8000 per SERVICE_PORTS)
#
# Legacy alias (DO NOT SET on the frontend — kept for backward compat
# with deployments that haven't migrated yet):
# PHASE1_SERVICE_URL=http://localhost:8000  # <-- REMOVE THIS FROM FRONTEND (FE-002 v143: canonical phase1_dataset port is 8000 per SERVICE_PORTS)

# ─── Phase 2: Knowledge Graph Service (DEPRECATED on frontend — now on backend) ─
# KG_SERVICE_URL is NO LONGER USED by the frontend. Set it on the backend.
# KG_SERVICE_URL=http://localhost:8001  # <-- on the backend process (TM13 v132: was 8002, fixed to match canonical contract)

# ─── Phase 3: Graph Transformer Service (DEPRECATED on frontend — now on backend) ─
# TEAMMATE-11 ROOT FIX (P3 → Backend + Frontend Integration): the frontend
# NO LONGER calls the GT service directly. All /api/predict and /api/top-k
# requests go through the FastAPI backend (backend/api/main.py), which
# proxies to the GT service internally. The backend is the documented
# integration point for pharma partner API keys — every public API call
# passes through verify_jwt + verify_org_id + the rate limiter (100 req/min)
# + audit logging.
#
# GT_SERVICE_URL is NO LONGER USED by the frontend. Set it on the backend.
# GT_SERVICE_URL=http://localhost:8002  # <-- on the backend process (TM13 v132: was 8003, fixed to match canonical contract)
# GT_CHECKPOINT_PATH=/path/to/gt_checkpoint.pt  # <-- on the backend process
#
# The frontend's API base is configured via NEXT_PUBLIC_API_BASE_URL
# (defaults to /api which works in Next.js dev/prod where the backend
# is mounted at /api/*). Override only when the FastAPI backend runs on
# a different host (e.g., https://api.drugos.ai/).
# NEXT_PUBLIC_API_BASE_URL=/api

# ─── Phase 4: RL Hypothesis Ranker Service (DEPRECATED on frontend — now on backend) ─
# RL_SERVICE_URL is NO LONGER USED by the frontend. Set it on the backend.
# RL_SERVICE_URL=http://localhost:8003  # <-- on the backend process (TM13 v132: was 8004, fixed to match canonical contract)

# ─── Database (Prisma) ─────────────────────────────────────────────────────
# PostgreSQL URL for the frontend's own Prisma DB (users, projects,
# hypotheses, audit logs). NOT the Phase 1 staging DB.
DATABASE_URL="postgresql://drugos:drugos@localhost:5432/drugos?schema=public"

# ─── Auth ──────────────────────────────────────────────────────────────────
# NextAuth.js configuration. Generate a secret with: openssl rand -base64 32
# IMPORTANT: this secret MUST match the JWT_SECRET env var on the backend
# (the FastAPI service uses the same secret to verify the JWTs the frontend
# issues). If they don't match, the backend's verify_jwt will reject every
# request with 401.
NEXTAUTH_SECRET=replace-me-with-a-random-secret-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# ─── Neo4j (optional, for Phase 2 service in production) ───────────────────
# When set, the Phase 2 service reads KG stats from Neo4j instead of
# building the graph in-memory from CSVs. Set on the BACKEND, not the frontend.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ─── NCBI / ClinicalTrials.gov / openFDA API keys (optional) ───────────────
# These are used by the evidence-package service to query real biomedical
# databases. Without keys, the services use lower rate limits.
# NCBI_API_KEY=
# CTGOV_API_KEY=
# OPENFDA_API_KEY=
