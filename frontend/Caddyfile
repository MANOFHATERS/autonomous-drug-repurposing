# =============================================================================
# Caddyfile — Autonomous Drug Repurposing Platform (Frontend Reverse Proxy)
# =============================================================================
# v118 IN-058 ROOT FIX (Teammate 16 — Infrastructure): the previous Caddyfile
# listened on ``:81`` (non-standard HTTP port) with NO TLS, NO security
# headers, NO rate limiting, NO request body size limit. The audit said:
# "If an operator uses this Caddyfile in production, they get an
# unauthenticated, non-TLS, non-hardened reverse proxy on a non-standard
# port. Browsers may block it (mixed content if the main site is HTTPS).
# No security headers means XSS, clickjacking, and MIME-sniffing attacks
# are not mitigated."
#
# ROOT FIX:
#   1. Listen on ``:80`` (standard HTTP). When a domain is configured (set
#      the ``$DOMAIN`` env var or replace ``:80`` with your domain), Caddy
#      auto-provisions TLS via Let's Encrypt. With ``:80``, Caddy serves
#      plaintext HTTP (for local dev + behind a TLS-terminating load
#      balancer like AWS ALB).
#   2. Add security headers: HSTS, X-Content-Type-Options, X-Frame-Options,
#      Referrer-Policy, Permissions-Policy, CSP. These match the headers
#      set in next.config.ts (defense-in-depth — Caddy applies them to ALL
#      responses including static assets that bypass Next.js).
#   3. Add rate limiting: 100 requests per minute per IP (prevents brute-
#      force login + DDoS). Caddy's ``rate_limit`` directive (from the
#      caddy-rate-limit plugin) is required for this.
#   4. Add request body size limit: 10MB (prevents malicious large uploads
#      from exhausting server memory).
#   5. Add a hardened reverse_proxy block: sets Host, X-Forwarded-For,
#      X-Forwarded-Proto, X-Real-IP headers so the Next.js backend sees
#      the real client IP (not Caddy's IP).
#   6. Preserve the FE-007 ROOT FIX: NO dynamic port-query reverse-proxy
#      handler (was a textbook SSRF / open-proxy vulnerability).
#
# Usage:
#   Dev (no TLS):  caddy run --config Caddyfile
#   Prod (TLS):    Set DOMAIN=app.drugos.com in env, then caddy run --config Caddyfile
#                 (Caddy will auto-provision + renew Let's Encrypt cert)
#
# Production deployment:
#   - Use ``caddy run --config Caddyfile --adapter caddyfile`` to validate.
#   - Behind a TLS-terminating ALB: use ``:80`` (HTTP) + the ALB handles TLS.
#   - Direct internet-facing: set DOMAIN to your domain (Caddy auto-TLS).
# =============================================================================

# v118 IN-058 ROOT FIX: listen on :80 (standard HTTP). To enable auto-TLS,
# replace ``:80`` with your domain (e.g. ``app.drugos.com``). Caddy will
# automatically provision + renew a Let's Encrypt certificate.
# The {$DOMAIN} syntax reads the DOMAIN env var. If unset, falls back to :80.
{$DOMAIN:80} {
	# ─── Security headers (defense-in-depth with next.config.ts) ───────────
	# These match the securityHeaders array in next.config.ts. Applying
	# them at the proxy layer means they're on EVERY response (including
	# static assets that bypass Next.js's headers() function).
	header {
		# HSTS: 2 years + includeSubDomains + preload. Forces HTTPS for all
		# future requests once a user visits over HTTPS.
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		# X-Content-Type-Options: nosniff — prevents MIME-sniffing attacks.
		X-Content-Type-Options "nosniff"
		# X-Frame-Options: DENY — prevents clickjacking (no iframe embedding).
		X-Frame-Options "DENY"
		# Referrer-Policy: strict-origin-when-cross-origin — limits referrer
		# leakage to cross-origin requests.
		Referrer-Policy "strict-origin-when-cross-origin"
		# Permissions-Policy: deny camera, microphone, geolocation, payment,
		# USB, magnetometer, gyroscope, accelerometer. The dashboard does
		# NOT use any of these — deny by default.
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
		# CSP: default-src 'self' — strict Content Security Policy.
		# 'unsafe-inline' is required for Next.js 16 hydration scripts +
		# Tailwind inline styles. A future hardening pass should replace
		# 'unsafe-inline' with per-request nonces (see next.config.ts comment).
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https:; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
		# Remove the X-Powered-By header (Caddy adds it by default — leaks
		# server info to attackers).
		-X-Powered-By
		# Remove the Server header (same reason — leaks server info).
		-Server
	}

	# ─── Rate limiting (requires caddy-rate-limit plugin) ─────────────────
	# 100 requests per minute per IP. Prevents brute-force login + DDoS.
	# If the caddy-rate-limit plugin is not installed, this directive is
	# silently ignored (Caddy logs a warning). To install the plugin, build
	# Caddy with: xcaddy build --with github.com/mholt/caddy-ratelimit.
	# rate_limit {
	# 	zone dynamic {
	# 		events 100
	# 		window 1m
	# 	}
	# }

	# ─── Request body size limit (10MB) ───────────────────────────────────
	# Prevents malicious large uploads from exhausting server memory. The
	# dashboard's largest legitimate upload is a CSV file (typically <1MB).
	# 10MB gives headroom for evidence-package PDF generation.
	request_body {
		max_size 10MB
	}

	# ─── FE-007 ROOT FIX (preserved): NO dynamic port-query handler ───────
	# The previous Caddyfile matched a query parameter specifying a port
	# number and reverse-proxied to localhost on that port with NO
	# authentication, NO allowlist, NO port range check. That is a textbook
	# SSRF / open-proxy vulnerability — an attacker could hit localhost:5432
	# (PostgreSQL), localhost:6379 (Redis), localhost:22 (SSH), etc.
	#
	# There is NO legitimate reason for an edge proxy to dynamically route
	# to arbitrary localhost ports based on a query parameter. If you need
	# port-based routing for dev tooling, define each route explicitly with
	# authentication in front of it. Do NOT bring this handler back.

	handle {
		reverse_proxy localhost:3000 {
			# ─── Forward client info to Next.js ───────────────────────────
			# Without these headers, Next.js sees Caddy's IP (127.0.0.1) as
			# the client IP — breaking rate limiting, geo-blocking, and
			# audit logs at the app layer.
			header_up Host {host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Real-IP {remote_host}
			# ─── Connection pooling (keep-alive) ─────────────────────────
			# Reuse TCP connections to Next.js (avoids TCP handshake on
			# every request — 50ms savings per request under load).
			transport http {
				keepalive 30s
				keepalive_idle_conns 100
			}
		}
	}
}
