// DrugOS Backend Schema
// BE-066 + BE-067 ROOT FIX: All role/status/visibility fields converted from
// free-form String to Prisma enums. Previously a raw SQL insert or a
// migration gone wrong could set role="superuser" — the application would
// treat it as a non-admin role (requireAdmin checks role === "admin" ||
// role === "owner"), but the user would have a role that doesn't match any
// allowlist. Enums enforce valid values at the DATABASE level, closing the
// SQL-injection / DBA-mistake hole completely.
// PostgreSQL-backed persistence for users, organizations, projects, billing,
// collaboration, evidence packages, audit logs, notifications, and API keys.
//
// PRODUCTION STORAGE: PostgreSQL (per project docx: "Storage: PostgreSQL + S3").
// SQLite is forbidden in production because it lacks row-level locks, type
// enforcement, and concurrent-write semantics required for a multi-tenant
// pharma platform handling PHI/PII.
//
// NOTE: Knowledge graph nodes/edges, raw dataset tables, and RL model artifacts
// are intentionally NOT modeled here — those are owned by the standalone ML
// services (Neo4j graph, Airflow data pipeline, Stable-Baselines3 RL agent).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // FE-019 ROOT FIX: Switched from sqlite to postgresql. The project doc
  // (Team_Cosmic_Build_Process_Updated.docx, Section 9 "Technology Stack")
  // explicitly requires "Storage: PostgreSQL + S3". SQLite cannot enforce
  // type constraints, doesn't support concurrent writes (single-writer lock),
  // and has different concurrency semantics — production under load would
  // corrupt.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS — BE-066 + BE-067: DB-level enforcement of allowed values.
// ---------------------------------------------------------------------------

enum UserRole {
  researcher
  admin
  owner
  billing
  viewer
  data_scientist
  pi
  business_dev
  developer
}

enum UserStatus {
  active
  suspended
  pending_approval
}

enum OrgMemberRole {
  owner
  admin
  member
  viewer
  billing
}

enum ProjectStatus {
  active
  archived
  completed
  on_hold
}

enum ProjectVisibility {
  private
  org
  public
}

enum HypothesisStatus {
  draft
  predicted
  reviewing
  validated
  rejected
  archived
}

enum SubscriptionStatus {
  active
  canceled
  past_due
  trialing
}

enum InvoiceStatus {
  open
  paid
  void
  uncollectible
}

enum EvidencePackageStatus {
  draft
  generated
  published
}

// ---------------------------------------------------------------------------
// AUTH & USERS
// ---------------------------------------------------------------------------

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  passwordHash      String
  name              String?
  // BE-066 ROOT FIX: role is now a Prisma enum (UserRole), not a free-form
  // String. A raw SQL insert with an invalid role will fail at the DB level.
  role              UserRole      @default(researcher)
  title             String?       // e.g. "Principal Scientist"
  bio               String?
  // BE-066 ROOT FIX: status is now a Prisma enum (UserStatus).
  status            UserStatus    @default(active)
  mfaSecret         String?
  mfaEnabled        Boolean       @default(false)
  emailVerified     Boolean       @default(false)
  academicVerified  Boolean       @default(false)
  // BE-062 ROOT FIX: When a user is removed from an organization, this
  // timestamp is set to the current time. It is included in the JWT as the
  // `omv` claim (orgMembershipVersion). On every authenticated request,
  // getAuthenticatedUser checks that the user's claimed orgId still matches
  // their active membership. If this timestamp is newer than the JWT's iat
  // (issued at), the token is treated as invalid — forcing re-authentication.
  // This closes the 15-minute window where a removed user retains access.
  orgMembershipRevokedAt DateTime?
  // FE-009 ROOT FIX: Brute-force protection. After 5 failed logins within
  // the lockout window, the account is locked until `lockedUntil`. The
  // `failedLoginCount` resets on successful login or when the lockout
  // window expires.
  failedLoginCount  Int           @default(0)
  lockedUntil       DateTime?
  // FE-033 ROOT FIX: TOTP replay protection. Stores the counter (30s
  // window index) of the last successfully-used TOTP code. RFC 6238 §5.2
  // recommends rejecting reused codes — without this, an attacker who
  // phishes a single TOTP code can replay it within the ±30s window.
  // verifyTotpWithReplayCheck rejects any code whose counter is <= this
  // value. Null means no code has been used yet.
  lastTotpCounter   BigInt?
  // FE-055: Soft-delete timestamp. Null = active. Set when an admin
  // deletes a user — the row is preserved for audit trails but login
  // is refused. (Added by team-15 — login route references it.)
  deletedAt         DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organizationMemberships OrganizationMember[]
  projects                Project[]
  apiKeys                 ApiKey[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  evidencePackages        EvidencePackage[]
  billingInvoices         BillingInvoice[]
  refreshTokens           RefreshToken[]

  @@index([status])
  @@index([role])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("free") // free | researcher | team | enterprise
  // BE-067 ROOT FIX: status is now a Prisma enum (ProjectStatus pattern).
  // Organization status uses the same values as Project for simplicity.
  status      ProjectStatus @default(active)
  seats       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members           OrganizationMember[]
  projects          Project[]
  apiKeys           ApiKey[]
  billingInvoices   BillingInvoice[]
  subscription      Subscription?

  @@index([plan])
  @@index([status])
}

model OrganizationMember {
  id              String       @id @default(cuid())
  userId          String
  organizationId  String
  // BE-067 ROOT FIX: role is now a Prisma enum (OrgMemberRole).
  role            OrgMemberRole @default(member)
  invitedBy       String?
  joinedAt        DateTime     @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// FE-016 ROOT FIX: MFA challenge-token replay protection. Each MFA challenge
// JWT now carries a random `jti` (JWT ID). /api/auth/2fa/login-verify
// atomically inserts the jti here on first use; the unique constraint on
// `jti` makes a second insert fail (Prisma P2002), which the verify route
// treats as a replay attack and rejects with 401. Rows are garbage-collected
// by a periodic job (or manually) once `expiresAt` has passed.
model MfaChallenge {
  id         String   @id @default(cuid())
  jti        String   @unique // FE-016: single-use replay guard
  userId     String
  consumedAt DateTime @default(now())
  expiresAt  DateTime // 1 min grace past the JWT's own expiry for clock skew

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// PROJECTS & COLLABORATION
// ---------------------------------------------------------------------------

model Project {
  id              String       @id @default(cuid())
  name            String
  description     String?
  // BE-067 ROOT FIX: status is now a Prisma enum (ProjectStatus).
  status          ProjectStatus    @default(active)
  // BE-067 ROOT FIX: visibility is now a Prisma enum (ProjectVisibility).
  visibility      ProjectVisibility @default(private)
  ownerId         String
  organizationId  String
  tags            String       @default("") // comma-separated
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  owner           User           @relation(fields: [ownerId], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id])
  hypotheses      Hypothesis[]
  comments        Comment[]
  activities      ProjectActivity[]
  evidencePackages EvidencePackage[]

  // FE-018 ROOT FIX: Missing index on organizationId — every org-scoped
  // project list query was a full table scan.
  @@index([organizationId])
  @@index([ownerId])
  @@index([status])
}

model Hypothesis {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  drugName      String
  diseaseName   String
  // FE-010 ROOT FIX: status enum tightened. RL model predictions are stored
  // with status="predicted" (NOT "validated" — a "validated" hypothesis in
  // pharma means wet-lab or clinical confirmation, which a model output is
  // NOT). The rlPredicted boolean below distinguishes RL-sourced hypotheses
  // from human-created ones at query time.
  // BE-067 ROOT FIX: status is now a Prisma enum (HypothesisStatus).
  status        HypothesisStatus @default(draft)
  // FE-010 ROOT FIX: true when this hypothesis was created or last updated
  // by the RL ranker (via /api/rl persistRlCandidates). Lets researchers
  // filter "RL predictions" vs "human-curated hypotheses" vs "validated by
  // wet-lab" — three distinct categories that were previously conflated.
  rlPredicted   Boolean  @default(false)
  // The three scores managed by the standalone RL agent — we store the
  // most recent values for display, but the RL agent is the source of truth.
  plausibilityScore  Float?
  safetyScore        Float?
  marketScore        Float?
  overallScore       Float?
  // FE-002: RL ranker output fields (persisted by rl-ranker service).
  rank               Int?
  policyProb         Float?
  reward             Float?
  gnnScore           Float?
  literatureSupport  Boolean?
  rlModelVersion     String?
  rlUpdatedAt        DateTime?
  notes        String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidencePackages EvidencePackage[]

  // FE-018 ROOT FIX: Missing index on projectId.
  // FE-010: index on rlPredicted so "show me RL predictions" queries don't
  // full-scan the Hypothesis table.
  @@index([projectId])
  @@index([drugName])
  @@index([diseaseName])
  @@index([status])
  @@index([rlPredicted])
}

model Comment {
  id         String   @id @default(cuid())
  projectId  String
  userId     String?
  authorName String
  body       String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // FE-018 ROOT FIX: Missing index on projectId.
  @@index([projectId])
  @@index([createdAt])
}

model ProjectActivity {
  id         String   @id @default(cuid())
  projectId  String
  type       String   // hypothesis_created | status_changed | comment_added | file_uploaded
  actorName  String
  summary    String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // FE-018 ROOT FIX: Missing index on projectId.
  @@index([projectId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// BILLING
// ---------------------------------------------------------------------------

model Subscription {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  plan            String       @default("free")
  // BE-067 ROOT FIX: status is now a Prisma enum (SubscriptionStatus).
  status          SubscriptionStatus @default(active)
  seats           Int          @default(1)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model BillingInvoice {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  number          String   @unique
  amountCents     Int
  currency        String   @default("usd")
  // BE-067 ROOT FIX: status is now a Prisma enum (InvoiceStatus).
  status          InvoiceStatus @default(open)
  periodStart     DateTime
  periodEnd       DateTime
  dueDate         DateTime
  pdfUrl          String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
}

// ---------------------------------------------------------------------------
// EVIDENCE PACKAGES
// ---------------------------------------------------------------------------

model EvidencePackage {
  id            String   @id @default(cuid())
  projectId     String?
  hypothesisId  String?
  userId        String?
  drugName      String
  diseaseName   String
  title         String
  summary       String
  payloadJson   String   // serialized bundle: literature, trials, safety signals
  pdfPath       String?
  // BE-067 ROOT FIX: status is now a Prisma enum (EvidencePackageStatus).
  status        EvidencePackageStatus @default(draft)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project    Project?    @relation(fields: [projectId], references: [id])
  hypothesis Hypothesis? @relation(fields: [hypothesisId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([drugName])
  @@index([diseaseName])
  @@index([status])
}

// ---------------------------------------------------------------------------
// API KEYS (Developer platform)
// ---------------------------------------------------------------------------

model ApiKey {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  name            String
  hashedKey       String   @unique // FE-018: enforced unique + indexed
  prefix          String   // FE-038: 8 hex chars AFTER the "drugos_" marker, shown in UI for identification
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  // FE-018 ROOT FIX: missing indexes added for org/user/revokedAt lookups.
  @@index([organizationId])
  @@index([userId])
  @@index([revokedAt])
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS & AUDIT
// ---------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // info | success | warning | error
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model AuditLog {
  id              String   @id @default(cuid())
  userId          String?
  // FE-040 ROOT FIX: organizationId is required for multi-tenant audit-trail
  // isolation. The previous schema had only userId + actorName — meaning
  // audit logs could not be scoped to an org for query purposes, a user
  // who was a member of multiple orgs had their actions conflated across
  // orgs, and GDPR/CCPA data-subject-access-requests could not be scoped
  // to a specific org. The field is nullable ONLY for system-level events
  // (e.g. failed-login on a non-existent email) that are not tied to any
  // org. All user-initiated writes populate it from the authenticated
  // user's orgId via writeAuditLog.
  organizationId  String?
  actorName       String
  action          String   // login | logout | hypothesis_create | billing_change | admin_action
  resource        String?
  ip              String?
  userAgent       String?
  metadata        String   @default("{}") // JSON string
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  // FE-018 ROOT FIX: Missing index on createdAt — audit log queries by
  // time range were full table scans.
  @@index([createdAt])
  // FE-040 ROOT FIX: index on organizationId for per-org audit-log queries
  // (compliance reporting, DSARs, multi-tenant scoping).
  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// WEBHOOKS
// ---------------------------------------------------------------------------

// BE-069 ROOT FIX: The WebhookEndpoint model and the lib/crypto.ts module
// have been REMOVED. There was NO /api/webhooks route — the model was dead
// code. The WebhooksScreen UI rendered hardcoded fake webhooks (ISSUE-FE-011).
// The crypto module (AES-256-GCM encryption for webhook secrets) was never
// called. Removing them eliminates confusion and reduces attack surface.
//
// If webhooks become a near-term roadmap item, re-add the model with proper
// CRUD routes and a delivery service. Until then, they are intentionally
// absent.
