// DrugOS Backend Schema
// PostgreSQL-backed persistence for users, organizations, projects, billing,
// collaboration, evidence packages, audit logs, notifications, and API keys.
//
// PRODUCTION STORAGE: PostgreSQL (per project docx: "Storage: PostgreSQL + S3").
// SQLite is forbidden in production because it lacks row-level locks, type
// enforcement, and concurrent-write semantics required for a multi-tenant
// pharma platform handling PHI/PII.
//
// NOTE: Knowledge graph nodes/edges, raw dataset tables, and RL model artifacts
// are intentionally NOT modeled here — those are owned by the standalone ML
// services (Neo4j graph, Airflow data pipeline, Stable-Baselines3 RL agent).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // FE-019 ROOT FIX: Switched from sqlite to postgresql. The project doc
  // (Team_Cosmic_Build_Process_Updated.docx, Section 9 "Technology Stack")
  // explicitly requires "Storage: PostgreSQL + S3". SQLite cannot enforce
  // type constraints, doesn't support concurrent writes (single-writer lock),
  // and has different concurrency semantics — production under load would
  // corrupt.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// AUTH & USERS
// ---------------------------------------------------------------------------

model User {
  id                String        @id @default(cuid())
  email             String        @unique
  passwordHash      String
  name              String?
  role              String        @default("researcher") // researcher | admin | owner | billing | viewer | data-scientist | pi | business-dev | developer
  title             String?       // e.g. "Principal Scientist"
  bio               String?
  status            String        @default("active")     // active | suspended | pending_approval
  mfaSecret         String?
  mfaEnabled        Boolean       @default(false)
  emailVerified     Boolean       @default(false)
  academicVerified  Boolean       @default(false)
  // FE-009 ROOT FIX: Brute-force protection. After 5 failed logins within
  // the lockout window, the account is locked until `lockedUntil`. The
  // `failedLoginCount` resets on successful login or when the lockout
  // window expires.
  failedLoginCount  Int           @default(0)
  lockedUntil       DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  organizationMemberships OrganizationMember[]
  projects                Project[]
  apiKeys                 ApiKey[]
  auditLogs               AuditLog[]
  notifications           Notification[]
  evidencePackages        EvidencePackage[]
  billingInvoices         BillingInvoice[]
  refreshTokens           RefreshToken[]

  @@index([status])
  @@index([role])
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  plan        String   @default("free") // free | researcher | team | enterprise
  status      String   @default("active")
  seats       Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members           OrganizationMember[]
  projects          Project[]
  apiKeys           ApiKey[]
  billingInvoices   BillingInvoice[]
  subscription      Subscription?

  @@index([plan])
  @@index([status])
}

model OrganizationMember {
  id              String       @id @default(cuid())
  userId          String
  organizationId  String
  role            String       @default("member") // owner | admin | member | viewer | billing
  invitedBy       String?
  joinedAt        DateTime     @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------------
// PROJECTS & COLLABORATION
// ---------------------------------------------------------------------------

model Project {
  id              String       @id @default(cuid())
  name            String
  description     String?
  status          String       @default("active") // active | archived | completed | on_hold
  visibility      String       @default("private") // private | org | public
  ownerId         String
  organizationId  String
  tags            String       @default("") // comma-separated
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  owner           User           @relation(fields: [ownerId], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id])
  hypotheses      Hypothesis[]
  comments        Comment[]
  activities      ProjectActivity[]
  evidencePackages EvidencePackage[]

  // FE-018 ROOT FIX: Missing index on organizationId — every org-scoped
  // project list query was a full table scan.
  @@index([organizationId])
  @@index([ownerId])
  @@index([status])
}

model Hypothesis {
  id            String   @id @default(cuid())
  projectId     String
  title         String
  drugName      String
  diseaseName   String
  status        String   @default("draft") // draft | reviewing | validated | rejected | archived
  // The three scores managed by the standalone RL agent — we store the
  // most recent values for display, but the RL agent is the source of truth.
  plausibilityScore  Float?
  safetyScore        Float?
  marketScore        Float?
  overallScore       Float?
  notes        String?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project          Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidencePackages EvidencePackage[]

  // FE-018 ROOT FIX: Missing index on projectId.
  @@index([projectId])
  @@index([drugName])
  @@index([diseaseName])
  @@index([status])
}

model Comment {
  id         String   @id @default(cuid())
  projectId  String
  userId     String?
  authorName String
  body       String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // FE-018 ROOT FIX: Missing index on projectId.
  @@index([projectId])
  @@index([createdAt])
}

model ProjectActivity {
  id         String   @id @default(cuid())
  projectId  String
  type       String   // hypothesis_created | status_changed | comment_added | file_uploaded
  actorName  String
  summary    String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // FE-018 ROOT FIX: Missing index on projectId.
  @@index([projectId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// BILLING
// ---------------------------------------------------------------------------

model Subscription {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  plan            String       @default("free")
  status          String       @default("active") // active | canceled | past_due | trialing
  seats           Int          @default(1)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelAtPeriodEnd  Boolean   @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
}

model BillingInvoice {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String?
  number          String   @unique
  amountCents     Int
  currency        String   @default("usd")
  status          String   @default("open") // open | paid | void | uncollectible
  periodStart     DateTime
  periodEnd       DateTime
  dueDate         DateTime
  pdfUrl          String?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
}

// ---------------------------------------------------------------------------
// EVIDENCE PACKAGES
// ---------------------------------------------------------------------------

model EvidencePackage {
  id            String   @id @default(cuid())
  projectId     String?
  hypothesisId  String?
  userId        String?
  drugName      String
  diseaseName   String
  title         String
  summary       String
  payloadJson   String   // serialized bundle: literature, trials, safety signals
  pdfPath       String?
  status        String   @default("draft") // draft | generated | published
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project    Project?    @relation(fields: [projectId], references: [id])
  hypothesis Hypothesis? @relation(fields: [hypothesisId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([drugName])
  @@index([diseaseName])
  @@index([status])
}

// ---------------------------------------------------------------------------
// API KEYS (Developer platform)
// ---------------------------------------------------------------------------

model ApiKey {
  id              String   @id @default(cuid())
  organizationId  String
  userId          String
  name            String
  hashedKey       String   @unique // FE-018: enforced unique + indexed
  prefix          String   // first 8 chars shown in UI for identification
  lastUsedAt      DateTime?
  revokedAt       DateTime?
  createdAt       DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  // FE-018 ROOT FIX: missing indexes added for org/user/revokedAt lookups.
  @@index([organizationId])
  @@index([userId])
  @@index([revokedAt])
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS & AUDIT
// ---------------------------------------------------------------------------

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // info | success | warning | error
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  actorName  String
  action     String   // login | logout | hypothesis_create | billing_change | admin_action
  resource   String?
  ip         String?
  userAgent  String?
  metadata   String   @default("{}") // JSON string
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  // FE-018 ROOT FIX: Missing index on createdAt — audit log queries by
  // time range were full table scans.
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// WEBHOOKS
// ---------------------------------------------------------------------------

model WebhookEndpoint {
  id              String   @id @default(cuid())
  organizationId  String
  url             String
  // FE-017 ROOT FIX: Webhook signing secrets are now stored as AES-256-GCM
  // ciphertext (format: "v1:<base64 iv>:<base64 ciphertext>:<base64 tag>").
  // The plaintext secret is NEVER persisted. Encryption/decryption is handled
  // by lib/crypto.ts using WEBHOOK_SECRET_KEY (32-byte key, env var). This
  // means a DB backup leak does NOT expose signing secrets — an attacker
  // would also need the KMS/env var to forge webhook deliveries.
  secretEncrypted String
  events          String   @default("*") // comma-separated event types
  enabled         Boolean  @default(true)
  lastTriggeredAt DateTime?
  createdAt       DateTime @default(now())

  @@index([organizationId])
  @@index([enabled])
}
