{
  "name": "drugos-frontend",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "bash scripts/build-standalone.sh",
    "start": "NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint .",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "test": "bash scripts/run-all-tests.sh",
    "test:unit": "jest src/lib/services/__tests__/ --runInBand --forceExit",
    "test:integration": "node scripts/run-integration-tests.js",
    "test:e2e": "node scripts/run-e2e-tests.js",
    "tsc": "tsc --noEmit",
    "postinstall": "prisma generate || true",
    "gen:contracts": "python3 scripts/extract_openapi.py && node scripts/assemble-contracts.mjs",
    "check:contracts": "bash scripts/check-contracts.sh"
  },
